#include <stdio.h>

void towerOfHanoi(int n, char source, char aux, char dest) {
    // Base Case: If there is only 1 disk, simply move it from source to destination
    if (n == 1) {
        printf("Move disk 1 from rod %c to rod %c\n", source, dest);
        return;
    }

    // Step 1: Move top n-1 disks from Source to Auxiliary (using Dest as helper)
    towerOfHanoi(n - 1, source, dest, aux);

    // Step 2: Move the nth (largest) disk from Source to Destination
    printf("Move disk %d from rod %c to rod %c\n", n, source, dest);

    // Step 3: Move the n-1 disks from Auxiliary to Destination (using Source as helper)
    towerOfHanoi(n - 1, aux, source, dest);
}

int main() {
    int n;

    printf("Enter the number of disks: ");
    scanf("%d", &n);

    printf("\nSteps to solve Tower of Hanoi for %d disks\n", n);

    towerOfHanoi(n, 'S', 'A', 'D');

    return 0;
}
